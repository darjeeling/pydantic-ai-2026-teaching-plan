OPENAI_API_KEY=
COURSE_MODEL=openai:gpt-5.2
# Backward-compatible fallback used when COURSE_MODEL is unset.
OPENAI_MODEL=openai:gpt-5.2

# Optional model provider credentials for 0회차:
OPENROUTER_API_KEY=
# AWS Bedrock: use a bearer token, or the access-key pair plus AWS_DEFAULT_REGION.
AWS_BEARER_TOKEN_BEDROCK=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
# Google AI Studio / Gemini API and Vertex AI Express Mode can use GOOGLE_API_KEY.
GOOGLE_API_KEY=
# Google Cloud / Vertex AI with Application Default Credentials can use these.
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_LOCATION=us-central1

# Optional Logfire setup:
# Run `uv run logfire auth` and `uv run logfire projects use <project>` to create .logfire,
# or configure Logfire through environment variables in your own environment.
# LOGFIRE_CAPTURE_HTTPX=1 captures provider HTTP payloads for debugging. Use carefully.
# LOGFIRE_CAPTURE_HTTPX=1
# Local API call breadcrumbs. Default is logs/api-calls.log.
# COURSE_API_LOG_FILE=logs/api-calls.log
# COURSE_API_LOG_LEVEL=INFO
# COURSE_API_LOG_DISABLED=1
# Raw HTTPX teaching log. This intentionally logs prompt/response bodies.
# COURSE_RAW_HTTPX_LOG_FILE=logs/httpx-raw-api.log
# COURSE_RAW_HTTPX_PROMPT=Pydantic AI를 처음 배우는 사람에게 한 문단으로 설명해줘.
POSTGRES_DSN=postgresql://postgres:postgres@localhost:54320/pydantic_ai_course
POSTGRES_SERVER_DSN=postgresql://postgres:postgres@localhost:54320/postgres

# RAG embedding provider options:
# - openai: default, uses OpenAI embeddings API
# - ollama: local Ollama embedding server, e.g. `ollama pull embeddinggemma`
# - sentence-transformers: local Python model, requires `uv add sentence-transformers`
EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL=text-embedding-3-small
# Optional. Leave unset to let load_docs.py infer dimensions.
# EMBEDDING_DIMENSIONS=1536
OLLAMA_BASE_URL=http://127.0.0.1:11434
# SENTENCE_TRANSFORMERS_DEVICE=mps
# RESET_RAG_TABLE=1
